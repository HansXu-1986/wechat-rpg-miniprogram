/* 全局样式 */
page {
  background-color: #1a1a2e;
  color: #eee;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  border: none;
  margin: 10rpx 0;
}

.btn-primary {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.btn-success {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.btn-warning {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 16rpx 0;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #fff;
}

.text-muted {
  color: #aaa;
  font-size: 24rpx;
}

.stat-bar {
  width: 100%;
  height: 16rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 8rpx;
  overflow: hidden;
  margin: 8rpx 0;
}

.stat-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.stat-hp {
  background: linear-gradient(90deg, #f5576c, #f093fb);
}

.stat-exp {
  background: linear-gradient(90deg, #4facfe, #00f2fe);
}

.grid {
  display: flex;
  flex-wrap: wrap;
}

.grid-cell {
  box-sizing: border-box;
  padding: 8rpx;
}

.col-2 {
  width: 50%;
}

.col-3 {
  width: 33.33%;
}

.col-4 {
  width: 25%;
}
