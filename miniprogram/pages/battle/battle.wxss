.battle-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #1a1a2e;
  box-sizing: border-box;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 20rpx;
  background: rgba(0, 0, 0, 0.3);
  color: white;
}

.turn-info {
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
}

.battle-info {
  font-size: 24rpx;
}

.btn-sm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 6rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  border: none;
  line-height: 1;
}

.map-scroll {
  flex: 1;
  overflow: auto;
  padding: 10rpx;
}

.battle-map {
  position: relative;
  margin: 0 auto;
}

.map-row {
  position: relative;
}

.map-cell {
  position: absolute;
  box-sizing: border-box;
  border: 1px solid rgba(255, 255, 255, 0.2);
  transition: all 0.2s;
}

/* 地形样式 */
.map-cell.plain {
  background: rgba(100, 180, 100, 0.3);
}
.map-cell.mountain {
  background: rgba(150, 150, 150, 0.5);
}
.map-cell.forest {
  background: rgba(60, 120, 60, 0.5);
}
.map-cell.river {
  background: rgba(60, 120, 200, 0.5);
}
.map-cell.castle {
  background: rgba(150, 120, 80, 0.5);
}

.map-cell.highlight {
  border: 2px solid #f093fb;
  box-shadow: 0 0 10rpx #f093fb;
}

.map-cell.has-unit {
  border-width: 2px;
}

.unit {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 4rpx;
  box-sizing: border-box;
}

.unit.player {
  border: 2px solid #4facfe;
}

.unit.enemy {
  border: 2px solid #f5576c;
}

.unit-name {
  font-size: 18rpx;
  font-weight: bold;
  color: white;
  text-align: center;
  line-height: 1;
}

.unit-hp {
  font-size: 14rpx;
  color: white;
  line-height: 1;
  margin-top: 2rpx;
}

.action-panel {
  background: rgba(0, 0, 0, 0.4);
  padding: 16rpx;
}

.selected-info {
  color: white;
}

.selected-info.empty {
  text-align: center;
  color: #aaa;
  padding: 20rpx;
}

.unit-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
  font-size: 28rpx;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-buttons .btn-sm {
  flex: 1;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.modal-content {
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.modal-title {
  font-size: 36rpx;
  text-align: center;
  margin-bottom: 20rpx;
  color: white;
}

.modal-body {
  margin-bottom: 30rpx;
}

.modal-body text {
  display: block;
  margin: 10rpx 0;
  color: #ddd;
  font-size: 28rpx;
}
